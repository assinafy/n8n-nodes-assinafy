{
	"name": "n8n-nodes-assinafy",
	"version": "0.1.0",
	"description": "n8n community nodes for the Assinafy electronic-signature API (documents, signers, assignments, webhooks).",
	"license": "MIT",
	"homepage": "https://github.com/assinafy/n8n-nodes-assinafy",
	"keywords": [
		"n8n-community-node-package",
		"assinafy",
		"e-signature",
		"electronic-signature",
		"pdf",
		"contracts"
	],
	"author": {
		"name": "Assinafy",
		"email": "suporte@assinafy.com.br"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/assinafy/n8n-nodes-assinafy.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AssinafyApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Assinafy/Assinafy.node.js",
			"dist/nodes/AssinafyTrigger/AssinafyTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
